# OpenViking connection configuration
# This file is NOT committed to git. Copy from .env.example and fill in your values.

# -----------------------------------------------------------------------------
# OpenViking 服务连接配置
# -----------------------------------------------------------------------------

# OpenViking 服务地址，本地开发默认使用 http://127.0.0.1:1933
OPENVIKING_BASE_URL=http://127.0.0.1:1933

# OpenViking API Key，用于请求认证，空字符串表示不启用认证
OPENVIKING_API_KEY=

# 默认 Agent ID，用于标识当前插件实例。若 sessionId 中包含 agent:xxx: 前缀，
# 实际 Agent ID 会拼接为 "{OPENVIKING_AGENT_ID}_{session 中提取的 agentId}"
OPENVIKING_AGENT_ID=default

# OpenViking 账户 ID，多租户场景下用于路由到指定账户
OPENVIKING_ACCOUNT_ID=

# OpenViking 用户 ID，多租户场景下标识用户身份
OPENVIKING_USER_ID=

# HTTP 请求超时时间（毫秒），单次 OV API 调用超过此时长将抛出异常
OPENVIKING_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# 自动归档（Commit）配置
# -----------------------------------------------------------------------------

# 自动归档的 token 阈值。当 session 的 pending_tokens 超过此值时，
# 引擎会在处理完 transform 请求后异步触发一次归档（archive + memory extraction）。
# 设置为较大的值可减少归档频率，但会增加单次请求延迟。
OPENVIKING_COMMIT_TOKEN_THRESHOLD=8000

# -----------------------------------------------------------------------------
# 记忆召回（Recall）配置
# -----------------------------------------------------------------------------

# 每次召回返回的最大记忆条数（去重/过滤后的最终上限）
OPENVIKING_RECALL_LIMIT=10

# 召回最低相似度阈值（0~1），低于此值的记忆将被过滤丢弃。
# 值越大结果越精确但可能召回不足，值越小召回越全但噪音增加。
OPENVIKING_RECALL_SCORE_THRESHOLD=0.1

# 召回时注入记忆的 token 预算（约 4 字符/token）。
# 第一条记忆强制包含，后续记忆按预算截断，防止注入内容过长挤占对话上下文。
OPENVIKING_RECALL_TOKEN_BUDGET=2000

# 是否同时搜索 viking://resources（除 user/agent memories 外）。
# 开启后可召回技能、资源等结构化内容，但会增加搜索耗时。
OPENVIKING_RECALL_RESOURCES=false

# -----------------------------------------------------------------------------
# 消息捕获（Capture）配置
# -----------------------------------------------------------------------------

# 是否自动将对话消息捕获到 OpenViking session。
# 关闭后引擎仅执行召回，不保存新消息到 OV。
OPENVIKING_AUTO_CAPTURE=true

# 是否自动执行记忆召回并在消息中注入记忆文本。
# 关闭后 transform 请求将原样返回原始消息列表。
OPENVIKING_AUTO_RECALL=true

# 消息捕获过滤模式："semantic" 或 "keyword"。
# - semantic（默认）：所有通过基础过滤的消息都会被捕获
# - keyword：仅当消息匹配 memory trigger 正则时才会被捕获，更严格但减少噪音
OPENVIKING_CAPTURE_MODE=semantic

# 单条消息最大可捕获长度（字符数）。超过此长度的消息将被拒绝捕获，
# 防止超长输入（如粘贴的代码/日志）污染记忆库。
OPENVIKING_CAPTURE_MAX_LENGTH=8192

# -----------------------------------------------------------------------------
# Session 作用域隔离配置
# -----------------------------------------------------------------------------

# 是否按 Agent 隔离用户作用域。开启后不同 Agent 无法访问同一用户的记忆。
OPENVIKING_ISOLATE_USER_SCOPE_BY_AGENT=false

# 是否按用户隔离 Agent 作用域。开启后不同用户无法访问同一 Agent 的记忆。
OPENVIKING_ISOLATE_AGENT_SCOPE_BY_USER=true

# -----------------------------------------------------------------------------
# Session Bypass 配置
# -----------------------------------------------------------------------------

# Bypass 模式列表，逗号分隔。匹配的 session 将完全跳过 OpenViking 处理
#（不捕获、不召回、不归档）。支持 glob-like 语法：
#   *   匹配单段（不含 :）
#   **  匹配任意字符（含 :）
# 示例："agent:*:cron:**,test:**" 会跳过所有 agent 的 cron 任务 session 和 test 前缀 session
OPENVIKING_BYPASS_SESSION_PATTERNS=

# -----------------------------------------------------------------------------
# 诊断与日志配置
# -----------------------------------------------------------------------------

# 是否输出结构化诊断日志。开启后引擎会在各关键阶段输出 JSON 格式的 diag 日志，
# 格式：openviking: diag {"ts": ..., "stage": ..., "sessionId": ..., "data": ...}
# 便于监控和排查问题。
OPENVIKING_EMIT_DIAGNOSTICS=true
